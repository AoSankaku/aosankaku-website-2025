<canvas id="tetrahedron-canvas"></canvas>

<style>
  #tetrahedron-canvas {
    display: block;
    width: 100%;
    height: 250px;
    background-color: transparent;

    @media (min-width: 768px) {
      height: 400px;
    }
  }
</style>

<script>
  const canvas = document.getElementById("tetrahedron-canvas") as HTMLCanvasElement | null;
  if (!canvas) throw new Error("Canvas element not found");

  const startWithWorker = (width: number, height: number, isDark: boolean) => {
    const offscreen = canvas.transferControlToOffscreen();
    const worker = new Worker(
      new URL("../workers/tetrahedron.worker.js", import.meta.url),
      { type: "module" }
    );

    worker.addEventListener("message", (e) => {
      if (e.data.type === "webgl-unsupported") {
        worker.terminate();
      }
    });

    worker.postMessage(
      { type: "init", canvas: offscreen, width, height, isDark },
      [offscreen]
    );

    const resizeObs = new ResizeObserver((entries) => {
      const { inlineSize: w, blockSize: h } = entries[0].contentBoxSize[0];
      worker.postMessage({ type: "resize", width: w, height: h });
    });
    resizeObs.observe(canvas);

    const mutObs = new MutationObserver((mutations) => {
      mutations.forEach((m) => {
        if (m.attributeName === "class") {
          worker.postMessage({
            type: "theme",
            isDark: document.documentElement.classList.contains("dark"),
          });
        }
      });
    });
    mutObs.observe(document.documentElement, { attributes: true });

    document.addEventListener(
      "astro:before-swap",
      () => {
        resizeObs.disconnect();
        mutObs.disconnect();
        worker.postMessage({ type: "stop" });
        worker.terminate();
      },
      { once: true }
    );
  };

  const startOnMainThread = (width: number, height: number, isDark: boolean) => {
    import("../utils/tetrahedron-webgl.js").then(
      ({ VERT_SRC, FRAG_SRC, buildGeometry, mat4Perspective, mat4LookAt, mat4RotateY }) => {
        const gl = (canvas.getContext("webgl") || canvas.getContext("webgl2")) as WebGLRenderingContext | null;
        if (!gl) return;

        // Set drawing-buffer resolution
        const maxDpr = width < 768 ? 1.5 : 2;
        const dpr = Math.min(window.devicePixelRatio, maxDpr);
        canvas.width  = Math.round(width  * dpr);
        canvas.height = Math.round(height * dpr);

        // Compile shaders
        const makeShader = (type: number, src: string) => {
          const sh = gl.createShader(type)!;
          gl.shaderSource(sh, src);
          gl.compileShader(sh);
          return sh;
        };
        const prog = gl.createProgram()!;
        gl.attachShader(prog, makeShader(gl.VERTEX_SHADER,   VERT_SRC));
        gl.attachShader(prog, makeShader(gl.FRAGMENT_SHADER, FRAG_SRC));
        gl.linkProgram(prog);
        gl.useProgram(prog);

        // Upload geometry
        const geo = buildGeometry();

        const posBuf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, posBuf);
        gl.bufferData(gl.ARRAY_BUFFER, geo.positions, gl.STATIC_DRAW);
        const aPos = gl.getAttribLocation(prog, "aPos");
        gl.enableVertexAttribArray(aPos);
        gl.vertexAttribPointer(aPos, 3, gl.FLOAT, false, 0, 0);

        const nrmBuf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, nrmBuf);
        gl.bufferData(gl.ARRAY_BUFFER, geo.normals, gl.STATIC_DRAW);
        const aNorm = gl.getAttribLocation(prog, "aNorm");
        gl.enableVertexAttribArray(aNorm);
        gl.vertexAttribPointer(aNorm, 3, gl.FLOAT, false, 0, 0);

        // Cache uniform locations
        const uModelLoc   = gl.getUniformLocation(prog, "uModel");
        const uAmbientLoc = gl.getUniformLocation(prog, "uAmbient");
        const uProjLoc    = gl.getUniformLocation(prog, "uProj");

        // Set static uniforms
        gl.uniformMatrix4fv(gl.getUniformLocation(prog, "uView"), false,
          mat4LookAt(0, 0.5, 5.2, 0, 0, 0));
        gl.uniformMatrix4fv(uProjLoc, false,
          mat4Perspective(35, width / height, 0.1, 1000));
        gl.uniform1f(uAmbientLoc, isDark ? 0.0 : 1.0);

        // GL state
        gl.enable(gl.DEPTH_TEST);
        gl.clearColor(0, 0, 0, 0);
        gl.viewport(0, 0, canvas.width, canvas.height);

        const mutObs = new MutationObserver((mutations) => {
          mutations.forEach((m) => {
            if (m.attributeName === "class") {
              gl.uniform1f(uAmbientLoc,
                document.documentElement.classList.contains("dark") ? 0.0 : 1.0);
            }
          });
        });
        mutObs.observe(document.documentElement, { attributes: true });
        document.addEventListener("astro:before-swap", () => mutObs.disconnect(), { once: true });

        const resizeObs = new ResizeObserver((entries) => {
          const { inlineSize: w, blockSize: h } = entries[0].contentBoxSize[0];
          const newDpr = Math.min(window.devicePixelRatio, maxDpr);
          canvas.width  = Math.round(w * newDpr);
          canvas.height = Math.round(h * newDpr);
          gl.viewport(0, 0, canvas.width, canvas.height);
          gl.uniformMatrix4fv(uProjLoc, false, mat4Perspective(35, w / h, 0.1, 1000));
        });
        resizeObs.observe(canvas);
        document.addEventListener("astro:before-swap", () => resizeObs.disconnect(), { once: true });

        let rotY = 0;
        const animate = () => {
          rotY += 0.002;
          gl.clear(gl.COLOR_BUFFER_BIT | gl.DEPTH_BUFFER_BIT);
          gl.uniformMatrix4fv(uModelLoc, false, mat4RotateY(rotY));
          gl.drawArrays(gl.TRIANGLES, 0, 12);
          requestAnimationFrame(animate);
        };
        animate();
      }
    );
  };

  const supportsOffscreen =
    typeof OffscreenCanvas !== "undefined" &&
    typeof canvas.transferControlToOffscreen === "function";

  const intersectionObs = new IntersectionObserver(
    (entries, obs) => {
      if (entries[0].isIntersecting) {
        obs.disconnect();
        // Read dimensions here: layout is already computed by the IntersectionObserver
        const rect = canvas.getBoundingClientRect();
        const width = rect.width || canvas.offsetWidth;
        const height = rect.height || canvas.offsetHeight;
        const isDark = document.documentElement.classList.contains("dark");
        if (supportsOffscreen) {
          startWithWorker(width, height, isDark);
        } else {
          startOnMainThread(width, height, isDark);
        }
      }
    },
    { rootMargin: "500px" }
  );
  intersectionObs.observe(canvas);
</script>
