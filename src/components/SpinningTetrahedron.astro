<canvas id="tetrahedron-canvas"></canvas>

<style>
  #tetrahedron-canvas {
    display: block;
    width: 100%;
    height: 250px;
    background-color: transparent;

    @media (min-width: 768px) {
      height: 400px;
    }
  }
</style>

<script>
  const canvas = document.getElementById("tetrahedron-canvas") as HTMLCanvasElement | null;
  if (!canvas) throw new Error("Canvas element not found");

  const rect = canvas.getBoundingClientRect();
  const width = rect.width || canvas.offsetWidth;
  const height = rect.height || canvas.offsetHeight;
  const isDark = document.documentElement.classList.contains("dark");

  const startWithWorker = () => {
    const offscreen = canvas.transferControlToOffscreen();
    const worker = new Worker(
      new URL("../workers/tetrahedron.worker.js", import.meta.url),
      { type: "module" }
    );

    worker.addEventListener("message", (e) => {
      if (e.data.type === "webgl-unsupported") {
        worker.terminate();
      }
    });

    worker.postMessage(
      { type: "init", canvas: offscreen, width, height, isDark },
      [offscreen]
    );

    const resizeObs = new ResizeObserver((entries) => {
      const { inlineSize: w, blockSize: h } = entries[0].contentBoxSize[0];
      worker.postMessage({ type: "resize", width: w, height: h });
    });
    resizeObs.observe(canvas);

    const mutObs = new MutationObserver((mutations) => {
      mutations.forEach((m) => {
        if (m.attributeName === "class") {
          worker.postMessage({
            type: "theme",
            isDark: document.documentElement.classList.contains("dark"),
          });
        }
      });
    });
    mutObs.observe(document.documentElement, { attributes: true });

    document.addEventListener(
      "astro:before-swap",
      () => {
        resizeObs.disconnect();
        mutObs.disconnect();
        worker.postMessage({ type: "stop" });
        worker.terminate();
      },
      { once: true }
    );
  };

  const startOnMainThread = async () => {
    // Test WebGL availability before loading Three.js to avoid console errors
    const testCanvas = document.createElement("canvas");
    const testGl = testCanvas.getContext("webgl2") || testCanvas.getContext("webgl");
    if (!testGl) {
      return;
    }

    const [
      { Scene },
      { PerspectiveCamera },
      { WebGLRenderer },
      { TetrahedronGeometry },
      { MeshStandardMaterial },
      { Mesh },
      { AmbientLight },
      { PointLight },
      { Vector3 },
      { Matrix4 },
    ] = await Promise.all([
      import("three/src/scenes/Scene.js"),
      import("three/src/cameras/PerspectiveCamera.js"),
      import("three/src/renderers/WebGLRenderer.js"),
      import("three/src/geometries/TetrahedronGeometry.js"),
      import("three/src/materials/MeshStandardMaterial.js"),
      import("three/src/objects/Mesh.js"),
      import("three/src/lights/AmbientLight.js"),
      import("three/src/lights/PointLight.js"),
      import("three/src/math/Vector3.js"),
      import("three/src/math/Matrix4.js"),
    ]);

    const scene = new Scene();
    const camera = new PerspectiveCamera(35, width / height, 0.1, 1000);

    const renderer = new WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      powerPreference: "high-performance",
    });

    const maxPixelRatio = window.innerWidth < 768 ? 1.5 : 2;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, maxPixelRatio));
    renderer.setSize(width, height, false);

    const ambientLight = new AmbientLight(0xffffff, isDark ? 0.3 : 8);
    scene.add(ambientLight);
    const pointLight = new PointLight(0xffffff, 30);
    pointLight.position.set(0, 6, 7);
    scene.add(pointLight);

    const mutObs = new MutationObserver((mutations) => {
      mutations.forEach((m) => {
        if (m.attributeName === "class") {
          ambientLight.intensity = document.documentElement.classList.contains("dark") ? 0.3 : 8;
        }
      });
    });
    mutObs.observe(document.documentElement, { attributes: true });
    document.addEventListener("astro:before-swap", () => mutObs.disconnect(), { once: true });

    const radius = 1;
    const geometry = new TetrahedronGeometry(radius, 0);
    const upAxis = new Vector3(1, 0, -1).normalize();
    const rotationMatrix = new Matrix4().makeRotationAxis(upAxis, Math.atan(Math.sqrt(2)));
    geometry.applyMatrix4(rotationMatrix);
    geometry.translate(0, radius / 3, 0);

    const tetrahedron = new Mesh(
      geometry,
      new MeshStandardMaterial({ color: 0x0077ff, metalness: 0.8, roughness: 0.35 })
    );
    scene.add(tetrahedron);
    camera.position.z = 5.2;
    camera.position.y = 0.5;

    const resizeObs = new ResizeObserver((entries) => {
      const { inlineSize: w, blockSize: h } = entries[0].contentBoxSize[0];
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h, false);
    });
    resizeObs.observe(canvas);

    const animate = () => {
      requestAnimationFrame(animate);
      tetrahedron.rotation.y += 0.002;
      renderer.render(scene, camera);
    };
    animate();
  };

  const supportsOffscreen =
    typeof OffscreenCanvas !== "undefined" &&
    typeof canvas.transferControlToOffscreen === "function";

  const intersectionObs = new IntersectionObserver(
    (entries, obs) => {
      if (entries[0].isIntersecting) {
        obs.disconnect();
        if (supportsOffscreen) {
          startWithWorker();
        } else {
          startOnMainThread();
        }
      }
    },
    { rootMargin: "500px" }
  );
  intersectionObs.observe(canvas);
</script>
